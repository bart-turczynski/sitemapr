    given-names: Bart
    orcid: "https://orcid.org/0000-0002-8788-7980"
repository-code: "https://github.com/bart-turczynski/sitemapr"
url: "https://bart-turczynski.github.io/sitemapr/"
license: MIT
keywords:
  - sitemap
  - sitemaps
  - XML sitemap
  - sitemap index
  - Sitemap Protocol
  - URL discovery
  - XML validation
  - RSS
  - Atom
  - SEO
  - web crawling
  - R
  - rstats

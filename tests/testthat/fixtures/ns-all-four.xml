<?xml version="1.0" encoding="UTF-8"?>
<!-- All four extension namespaces (image, video, news, hreflang) on one
     document: exercises a runtime-generated mixed-namespace profile. -->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:image="http://www.google.com/schemas/sitemap-image/1.1"
        xmlns:video="http://www.google.com/schemas/sitemap-video/1.1"
        xmlns:news="http://www.google.com/schemas/sitemap-news/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">
  <url>
    <loc>https://example.com/story</loc>
    <image:image>
      <image:loc>https://example.com/img/story.jpg</image:loc>
    </image:image>
    <video:video>
      <video:thumbnail_loc>https://example.com/thumbs/story.jpg</video:thumbnail_loc>
      <video:title>Story video</video:title>
      <video:description>The story, in video form.</video:description>
      <video:content_loc>https://example.com/media/story.mp4</video:content_loc>
    </video:video>
    <news:news>
      <news:publication>
        <news:name>Example News</news:name>
        <news:language>en</news:language>
      </news:publication>
      <news:publication_date>2026-06-01</news:publication_date>
      <news:title>The story</news:title>
    </news:news>
    <xhtml:link rel="alternate" hreflang="de" href="https://example.com/de/story"/>
  </url>
</urlset>

<?xml version="1.0" encoding="UTF-8"?>
<!-- A generic XML document whose root (<catalog>) is neither a sitemap root
     (<urlset>/<sitemapindex>) nor a feed (<rss>/<feed>), so it sniffs as generic
     "xml" and yields UNSUPPORTED_ROOT. (This fixture was previously an <rss>
     feed; feeds are now parsed into rows, so a genuine non-feed root is used to
     keep exercising the UNSUPPORTED_ROOT path.) -->
<catalog xmlns="http://example.com/catalog">
  <product>
    <name>This is a product catalog, not a sitemap</name>
    <link>https://example.com/product/1</link>
  </product>
</catalog>

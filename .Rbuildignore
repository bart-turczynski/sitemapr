# R build/dev artifacts
^README\.Rmd$
^_pkgdown\.yml$
^site$
^.*\.Rproj$
^\.Rproj\.user$
^\.Rhistory$
^\.RData$
^\.Ruserdata$
^.*\.Rcheck$
^[^/]+\.tar\.gz$
^\.lintr$
^cran-comments\.md$
^CRAN-SUBMISSION$
^doc$
^Meta$
# Shared scaffold layer: everything below is dev tooling, not package content,
# and would otherwise trip "non-standard files/directories" in R CMD check.
^\.github$
^\.editorconfig$
^\.env$
^\.env\.example$
^\.gitattributes$
^\.gitignore$
^\.pre-commit-config\.yaml$
^air\.toml$
^\.fp$
^\.claude$
^tools$
^FP_CLAUDE\.md$
^FP_AGENTS\.md$
^_scratch$
^data-raw$
^docs$
^CLAUDE\.md$
^AGENTS\.md$
^CONTRIBUTING\.md$
^CODE_OF_CONDUCT\.md$
^SECURITY\.md$
^CHANGELOG\.md$
^CITATION\.cff$
^codemeta\.json$
^\.zenodo\.json$
^\.bestpractices\.json$
^\.DS_Store$
^ACKNOWLEDGMENTS\.md$
